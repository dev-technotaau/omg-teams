# ──────────────────────────────────────────────
#  App
# ──────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="OMG Teams"
NEXT_PUBLIC_APP_URL=http://localhost:3001

# ──────────────────────────────────────────────
#  Backend API (client-side, browser requests)
# ──────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1

# ──────────────────────────────────────────────
#  Backend Internal URL (server-side only — BFF route handlers)
#  NOT prefixed with NEXT_PUBLIC_ so it stays server-side.
# ──────────────────────────────────────────────
BACKEND_INTERNAL_URL=http://localhost:3000/api/v1

# ──────────────────────────────────────────────
#  BFF Cookie Configuration
# ──────────────────────────────────────────────
COOKIE_ACCESS_MAX_AGE_DAYS=7
COOKIE_REFRESH_MAX_AGE_DAYS=30

# ──────────────────────────────────────────────
#  WebSocket
# ──────────────────────────────────────────────
NEXT_PUBLIC_SOCKET_URL=http://localhost:3000

# ──────────────────────────────────────────────
#  Cloudflare Turnstile (Client-Side CAPTCHA)
# ──────────────────────────────────────────────
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# ──────────────────────────────────────────────
#  Sentry
# ──────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_DSN=

# ──────────────────────────────────────────────
#  Cloudinary / R2 Public URLs
# ──────────────────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_R2_PUBLIC_URL=

# ──────────────────────────────────────────────
#  Firebase (Client-Side)
# ──────────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
NEXT_PUBLIC_FIREBASE_DATABASE_URL=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# ──────────────────────────────────────────────
#  Web Push / VAPID
# ──────────────────────────────────────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# ──────────────────────────────────────────────
#  Analytics & Tracking (optional)
# ──────────────────────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_FB_PIXEL_ID=

# ──────────────────────────────────────────────
#  WebAuthn
# ──────────────────────────────────────────────
NEXT_PUBLIC_WEBAUTHN_RP_ID=
