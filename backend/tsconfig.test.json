{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": false,
    "declarationDir": null,
    "declarationMap": false,
    "sourceMap": true,
    "types": ["node", "jest"],
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "exactOptionalPropertyTypes": false
  },
  "include": [
    "src/**/*.ts",
    "test/**/*.ts"
  ]
}
