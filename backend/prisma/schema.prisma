// ══════════════════════════════════════════════
//  33.10 AUDIT & ANALYTICS (3 models)
// ══════════════════════════════════════════════

/// All CRUD actions platform-wide
model AuditLog {
  id         String   @id @default(cuid())
  userId     String?  @map("user_id")
  userRole   Role?    @map("user_role")
  action     String   // CREATE, UPDATE, DELETE, RESTORE, LOGIN, LOGOUT, etc.
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  changes    Json?    // { field: { old: ..., new: ... } }
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  timestamp  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entityType, entityId])
  @@index([timestamp])
  @@index([action])
  @@index([userId, timestamp], map: "idx_audit_user_time")
  @@map("audit_logs")
}

/// Pre-computed analytics aggregations
model AnalyticsSnapshot {
  id           String   @id @default(cuid())
  snapshotType String   @map("snapshot_type")
  periodStart  DateTime @map("period_start")
  periodEnd    DateTime @map("period_end")
  data         Json
  computedAt   DateTime @default(now()) @map("computed_at")

  @@index([snapshotType, periodStart])
  @@map("analytics_snapshots")
}

/// Platform health metrics
model PlatformHealthLog {
  id          String   @id @default(cuid())
  metricName  String   @map("metric_name")
  metricValue Json     @map("metric_value")
  recordedAt  DateTime @default(now()) @map("recorded_at")

  @@index([metricName, recordedAt])
  @@map("platform_health_logs")
}

/// Data archiving — aged records moved here for query performance (§23.5)
model ArchivedRecord {
  id         String   @id @default(cuid())
  entityType String   @map("entity_type") // CANDIDATE_REPORT, AUDIT_LOG, LOGIN_HISTORY, NOTIFICATION
  entityId   String   @map("entity_id")
  snapshot   Json     // Full row snapshot at time of archiving
  archivedAt DateTime @default(now()) @map("archived_at")
  // §Godview — who archived it, so admin can filter per-user
  actorId    String?  @map("actor_id")
  relatedUserId String? @map("related_user_id") // subject of the archived record, if user-scoped

  actor User? @relation("ArchivedRecordActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([entityType])
  @@index([archivedAt])
  @@index([actorId])
  @@index([relatedUserId])
  @@map("archived_records")
}

// ══════════════════════════════════════════════
//  33.11 PLATFORM CONFIGURATION (3 models)
// ══════════════════════════════════════════════

/// Platform-wide key-value settings
model PlatformSetting {
  id        String   @id @default(cuid())
  category  String
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by")

  @@index([category])
  @@map("platform_settings")
}

/// Admin-configurable dropdown values.
///
/// State and Location use two extra columns to model real geography:
///   - STATE rows carry their geographic `zone` (NORTH/SOUTH/EAST/WEST/CENTRAL)
///     so admin maps each state to a zone exactly once.
///   - LOCATION rows reference their parent STATE row via `parentId`. The
///     candidate form fetches all locations once and filters client-side
///     by the user-selected state, so the cascading dropdown is implicit.
///
/// `zoneSet` is the legacy SET_A/SET_B column kept around for the candidate
/// form's field-visibility logic only — it is NOT used to filter dropdowns.
model DropdownOption {
  id        String            @id @default(cuid())
  category  DropdownCategory
  value     String
  label     String
  zoneSet   ZoneSet?          @map("zone_set")
  zone      Zone?             // STATE rows only — geographic zone of the state
  parentId  String?           @map("parent_id") // LOCATION rows only — parent STATE row
  sortOrder Int               @default(0) @map("sort_order")
  isActive  Boolean           @default(true) @map("is_active")
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")

  parent   DropdownOption?  @relation("DropdownChildren", fields: [parentId], references: [id], onDelete: SetNull)
  children DropdownOption[] @relation("DropdownChildren")

  @@unique([category, value, zoneSet], map: "uq_dropdown_category_value_zoneset")
  @@index([category, isActive])
  @@index([category, zoneSet])
  @@index([category, zone])
  @@index([parentId])
  @@map("dropdown_options")
}

/// Customizable email templates
model EmailTemplate {
  id          String   @id @default(cuid())
  templateKey String   @unique @map("template_key")
  subject     String
  bodyHtml    String   @map("body_html")
  updatedAt   DateTime @updatedAt @map("updated_at")
  updatedBy   String?  @map("updated_by")

  @@map("email_templates")
}

