/// Basic leave records within attendance context
model LeaveRecord {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  date      DateTime @db.Date
  leaveType String   @map("leave_type")
  markedBy  String   @map("marked_by")
  remarks   String?
  createdAt DateTime @default(now()) @map("created_at")

  user   User @relation("LeaveRecordUser", fields: [userId], references: [id], onDelete: Cascade)
  marker User @relation("LeaveRecordMarker", fields: [markedBy], references: [id], onDelete: Restrict)

  @@unique([userId, date])
  @@map("leave_records")
}

// ══════════════════════════════════════════════
//  33.13 WEBHOOKS (1 model)
// ══════════════════════════════════════════════

/// Registered webhook endpoints for external integrations
model WebhookEndpoint {
  id          String   @id @default(cuid())
  url         String
  secret      String   // HMAC signing secret
  events      String[] // Array of event names to subscribe to
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdBy   String   @map("created_by")

  @@index([isActive])
  @@map("webhook_endpoints")
}

// ══════════════════════════════════════════════
//  §Godview — Per-user administrative data
// ══════════════════════════════════════════════

/// Hash history so admins can audit rotations and block reuse
model PasswordHistory {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  passwordHash String   @map("password_hash")
  changedBy    String?  @map("changed_by") // null = self, otherwise admin user id
  reason       String?  // e.g. "reset_by_admin", "self_change", "forced_rotation"
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("password_history")
}

/// Per-user webhook subscriptions (distinct from global WebhookEndpoint)
model WebhookSubscription {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  url         String
  secret      String
  events      String[] @default([])
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  lastDeliveryAt DateTime? @map("last_delivery_at")
  failureCount   Int       @default(0) @map("failure_count")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User @relation("WebhookSubscriptionOwner", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isActive])
  @@map("webhook_subscriptions")
}

/// Saved column visibility / density / page size per table per user
model TablePreference {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  tableKey  String   @map("table_key") // e.g. "admin-employees"
  columns   Json?    // { visible: [...], order: [...], pinned: [...] }
  density   String?  // "compact" | "normal" | "spacious"
  pageSize  Int?     @map("page_size")
  viewType  String?  @map("view_type") // "table" | "card"
  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tableKey])
  @@index([userId])
  @@map("table_preferences")
}

/// Saved filter presets per page per user
model FilterPreset {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  pageKey   String   @map("page_key")
  name      String
  filters   Json
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, pageKey])
  @@map("filter_presets")
}

/// Admin impersonation sessions for accountability
model ImpersonationSession {
  id            String    @id @default(cuid())
  adminId       String    @map("admin_id")
  targetUserId  String    @map("target_user_id")
  reason        String
  ipAddress     String?   @map("ip_address")
  userAgent     String?   @map("user_agent")
  startedAt     DateTime  @default(now()) @map("started_at")
  endedAt       DateTime? @map("ended_at")

  admin  User @relation("ImpersonationAdmin",  fields: [adminId],      references: [id], onDelete: Cascade)
  target User @relation("ImpersonationTarget", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([targetUserId])
  @@index([startedAt])
  @@map("impersonation_sessions")
}
