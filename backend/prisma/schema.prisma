/// Document type definitions
model DocumentType {
  id              String   @id @default(cuid())
  name            String
  code            String   @unique
  acceptedFormats String[] @map("accepted_formats") // ["pdf", "jpg", "png"]
  isRequired      Boolean  @default(true) @map("is_required")
  description     String?
  isActive        Boolean  @default(true) @map("is_active")
  sortOrder       Int      @default(0) @map("sort_order")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  employeeDocuments EmployeeDocument[]

  @@map("document_types")
}

/// Employee uploaded documents
model EmployeeDocument {
  id              String         @id @default(cuid())
  userId          String         @map("user_id")
  documentTypeId  String         @map("document_type_id")
  fileUrl         String?        @map("file_url")
  fileName        String?        @map("file_name")
  fileSize        Int?           @map("file_size")
  mimeType        String?        @map("mime_type")
  fileHash        String?        @map("file_hash") // SHA-256
  storageKey      String?        @map("storage_key")
  status          DocumentStatus @default(NOT_UPLOADED)
  verifiedBy      String?        @map("verified_by")
  verifiedAt      DateTime?      @map("verified_at")
  rejectedBy      String?        @map("rejected_by")
  rejectedAt      DateTime?      @map("rejected_at")
  rejectionReason String?        @map("rejection_reason")
  expiryDate      DateTime?      @map("expiry_date")
  adminNotes      String?        @map("admin_notes")
  version         Int            @default(1)
  uploadedAt      DateTime?      @map("uploaded_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  documentType DocumentType @relation(fields: [documentTypeId], references: [id], onDelete: Restrict)
  verifier     User?        @relation("DocumentVerifier", fields: [verifiedBy], references: [id], onDelete: SetNull)
  history      EmployeeDocumentHistory[]

  @@unique([userId, documentTypeId])
  @@index([userId])
  @@index([status])
  @@map("employee_documents")
}

/// Document status change history
model EmployeeDocumentHistory {
  id                 String   @id @default(cuid())
  employeeDocumentId String   @map("employee_document_id")
  action             String
  oldStatus          String?  @map("old_status")
  newStatus          String?  @map("new_status")
  reason             String?
  fileUrl            String?  @map("file_url")
  actionBy           String?  @map("action_by")
  createdAt          DateTime @default(now()) @map("created_at")

  document EmployeeDocument @relation(fields: [employeeDocumentId], references: [id], onDelete: Cascade)
  actor    User?            @relation(fields: [actionBy], references: [id], onDelete: SetNull)

  @@index([employeeDocumentId])
  @@map("employee_document_history")
}

/// Admin-generated offer letters
model OfferLetter {
  id                String             @id @default(cuid())
  userId            String             @map("user_id")
  referenceNumber   String             @unique @map("reference_number")
  variant           OfferLetterVariant
  templateVersion   Int?               @map("template_version")
  dynamicFields     Json?              @map("dynamic_fields")
  editorContent     String?            @map("editor_content") // HTML from Tiptap
  generatedFileUrl  String?            @map("generated_file_url")
  generatedFileHash String?            @map("generated_file_hash") // SHA-256
  storageKey        String?            @map("storage_key") // R2/Cloudinary key
  status            String             @default("DRAFT") // DRAFT | GENERATED | SENT
  generatedBy       String             @map("generated_by")
  generatedAt       DateTime           @default(now()) @map("generated_at")
  isArchived        Boolean            @default(false) @map("is_archived")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")

  user      User @relation("OfferLetterRecipient", fields: [userId], references: [id], onDelete: Cascade)
  generator User @relation("OfferLetterGenerator", fields: [generatedBy], references: [id], onDelete: Restrict)

  @@index([userId])
  @@map("offer_letters")
}

