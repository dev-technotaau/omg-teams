# ──────────────────────────────────────────────
#  Admin Seed (used by prisma db seed)
# ──────────────────────────────────────────────
ADMIN_EMAIL=omg.teams26@gmail.com
ADMIN_PASSWORD=OMG@Teams/26/2002

# ──────────────────────────────────────────────
#  App
# ──────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# Frontend URL (used for CORS, email links, redirects, etc.)
FRONTEND_URL=http://localhost:3001

# Backend internal URL (used for server-to-server calls)
BACKEND_INTERNAL_URL=http://localhost:3000

# ──────────────────────────────────────────────
#  Database (PostgreSQL)
# ──────────────────────────────────────────────
# Pooled connection URL (used by Prisma Client at runtime).
# Works with Supabase, Neon, local PostgreSQL, etc.
#
# Local:     postgresql://postgres:postgres@localhost:5432/omg_teams
# Supabase:  postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# Neon:      postgresql://[user]:[password]@[endpoint].neon.tech/omg_teams?sslmode=require
DATABASE_URL=

# Direct connection URL (bypasses PgBouncer / connection poolers).
# Required for migrations. If empty, DATABASE_URL is used.
DATABASE_DIRECT_URL=

# Shadow database URL (used by Prisma Migrate for diffing — optional).
DATABASE_SHADOW_URL=

# SSL mode: disable | prefer | require | verify-ca | verify-full
DATABASE_SSL_MODE=prefer

# Connection pool settings
DATABASE_POOL_SIZE=10
DATABASE_POOL_TIMEOUT=30
DATABASE_CONNECTION_TIMEOUT=10
DATABASE_IDLE_TIMEOUT=60

# ──────────────────────────────────────────────
#  Redis
# ──────────────────────────────────────────────
# Full URL (takes precedence) or host/port/password individually.
# Upstash: rediss://default:xxxxx@xxx.upstash.io:6379
REDIS_URL=
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ──────────────────────────────────────────────
#  JWT / Auth
# ──────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=30d
JWT_ALGORITHM=HS256
# For RS256/ES256: provide PEM-encoded keys (optional)
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# ──────────────────────────────────────────────
#  Cookies / BFF
# ──────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIE_SECRET=
COOKIE_ACCESS_MAX_AGE_DAYS=7
COOKIE_REFRESH_MAX_AGE_DAYS=30
CSRF_SECRET=
BFF_SECRET=

# ──────────────────────────────────────────────
#  Session (Redis-backed)
# ──────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=
SESSION_MAX_AGE=86400000
SESSION_IDLE_TIMEOUT_MINUTES=30
MAX_SESSIONS_PER_USER=5

# ──────────────────────────────────────────────
#  Auth Security
# ──────────────────────────────────────────────
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_DURATION_MINUTES=15
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX_ATTEMPTS=5

# ──────────────────────────────────────────────
#  Password Policy
# ──────────────────────────────────────────────
PASSWORD_MIN_LENGTH=8
PASSWORD_MAX_LENGTH=128
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBER=true
PASSWORD_REQUIRE_SPECIAL=true

# ──────────────────────────────────────────────
#  Field Encryption (AES-256-GCM)
# ──────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
FIELD_ENCRYPTION_KEY=

# ──────────────────────────────────────────────
#  Cloudflare Turnstile (CAPTCHA)
# ──────────────────────────────────────────────
CF_TURNSTILE_SECRET_KEY=

# ──────────────────────────────────────────────
#  SMTP / Email
# ──────────────────────────────────────────────
# Works with Mailgun, SendGrid, Amazon SES, Mailtrap, etc.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@omgteams.com
SMTP_FROM_NAME="OMG Teams"
SMTP_SECURE=false
EMAIL_REPLY_TO=
EMAIL_MAX_SEND_PER_HOUR=25000
EMAIL_MAX_SEND_PER_DAY=100000

# ──────────────────────────────────────────────
#  Cloudflare R2 (S3-compatible)
# ──────────────────────────────────────────────
# From https://dash.cloudflare.com → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

# ──────────────────────────────────────────────
#  Cloudinary (Image/Video processing)
# ──────────────────────────────────────────────
# From https://console.cloudinary.com/settings/api-keys
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ──────────────────────────────────────────────
#  File Upload Limits
# ──────────────────────────────────────────────
AVATAR_UPLOAD_MAX_SIZE=5242880
DOCUMENT_UPLOAD_MAX_SIZE=10485760
UPLOAD_DAILY_LIMIT_MB=100

# ──────────────────────────────────────────────
#  VirusTotal (Virus Scanning)
# ──────────────────────────────────────────────
VIRUSTOTAL_API_KEY=

# ──────────────────────────────────────────────
#  Signed URL TTL (seconds)
# ──────────────────────────────────────────────
SIGNED_URL_TTL=900

# ──────────────────────────────────────────────
#  Sentry (Error Tracking)
# ──────────────────────────────────────────────
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_RELEASE=

# ──────────────────────────────────────────────
#  WebAuthn (Passkey / FIDO2)
# ──────────────────────────────────────────────
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME="OMG Teams"

# ──────────────────────────────────────────────
#  Web Push (VAPID)
# ──────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:noreply@omgteams.com

# ──────────────────────────────────────────────
#  Firebase (Server-Side Admin SDK)
# ──────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT_ID=
FIREBASE_DATABASE_URL=
# Base64-encoded service account JSON, or path to JSON file
FIREBASE_SERVICE_ACCOUNT=

# ──────────────────────────────────────────────
#  Webhooks
# ──────────────────────────────────────────────
WEBHOOK_SECRET=
WEBHOOK_CALLBACK_URL=

# ──────────────────────────────────────────────
#  BullMQ (Job Queues)
# ──────────────────────────────────────────────
BULLMQ_DEFAULT_JOB_OPTIONS_ATTEMPTS=3
BULLMQ_DEFAULT_JOB_OPTIONS_BACKOFF=1000
BULLMQ_REMOVE_ON_COMPLETE=1000
BULLMQ_REMOVE_ON_FAIL=5000
BULLMQ_EMAIL_CONCURRENCY=5
BULLMQ_STORAGE_CONCURRENCY=3
BULLMQ_NOTIFICATION_CONCURRENCY=10

# ──────────────────────────────────────────────
#  OpenTelemetry
# ──────────────────────────────────────────────
OTEL_ENABLED=false
OTEL_SERVICE_NAME=omg-teams-backend
OTEL_EXPORTER_OTLP_ENDPOINT=
HONEYCOMB_API_KEY=

# ──────────────────────────────────────────────
#  Google Analytics (server-side)
# ──────────────────────────────────────────────
GA_MEASUREMENT_ID=
GA_API_SECRET=

# ──────────────────────────────────────────────
#  CORS
# ──────────────────────────────────────────────
# Comma-separated origins, or * for all
# Production: https://teams.opportunitymakers.in
CORS_ORIGIN=https://teams.opportunitymakers.in,http://localhost:3001

# ──────────────────────────────────────────────
#  Rate Limiting
# ──────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# ──────────────────────────────────────────────
#  Swagger
# ──────────────────────────────────────────────
# Set to false to disable /api-docs in production
SWAGGER_ENABLED=true
