{
  "name": "backend",
  "version": "1.0.0",
  "description": "OMG Teams Backend API",
  "main": "dist/index.js",
  "types": "dist/types/index.d.ts",
  "scripts": {
    "dev": "tsx watch --clear-screen=false -r tsconfig-paths/register src/index.ts",
    "dev:nodemon": "nodemon",
    "dev:debug": "tsx watch --inspect -r tsconfig-paths/register src/index.ts",
    "dev:all": "concurrently -k -n tsc,server -c cyan,green \"npm run typecheck:watch\" \"npm run dev\"",
    "build": "rimraf dist && tsc -p tsconfig.json && tsc-alias -p tsconfig.json && npm run build:copy",
    "build:copy": "copyfiles -u 1 \"src/templates/**/*\" dist",
    "build:check": "tsc --noEmit",
    "start": "node -r source-map-support/register dist/index.js",
    "start:prod": "cross-env NODE_ENV=production node -r source-map-support/register dist/index.js",
    "typecheck": "tsc --noEmit --pretty",
    "typecheck:watch": "tsc --noEmit --watch --pretty",
    "clean": "rimraf dist coverage .tsbuildinfo",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "jest --config jest.e2e.config.js",
    "test:ci": "cross-env CI=true jest --coverage --maxWorkers=2",
    "validate": "concurrently -g -n tsc,lint,test -c cyan,yellow,green \"npm run typecheck\" \"npm run lint\" \"npm run test:ci\"",
    "db:generate": "prisma generate",
    "db:migrate": "dotenv-cli -e .env -- prisma migrate dev --config=prisma.config.local.ts",
    "db:migrate:create": "prisma migrate dev --create-only --config=prisma.config.local.ts",
    "db:migrate:deploy": "dotenv-cli -e .env -- prisma migrate deploy --config=prisma.config.local.ts",
    "db:migrate:reset": "prisma migrate reset --config=prisma.config.local.ts",
    "db:push": "prisma db push --config=prisma.config.local.ts",
    "db:seed": "npx tsx prisma/seeds/seed.ts",
    "db:studio": "prisma studio",
    "db:format": "prisma format",
    "db:validate": "prisma validate",
    "prepare": "cd .. && husky || true",
    "postinstall": "npx prisma generate"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "engines": {
    "node": ">=18.0.0"
  },
